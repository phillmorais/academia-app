# Variáveis usadas pelo frontend (Vite) — expostas no navegador, isso é esperado.
# Pegue esses valores em: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Variáveis usadas SOMENTE pela função /api/tutor.js (servidor).
# NUNCA prefixe estas com VITE_ — isso vazaria a chave para o navegador.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui
